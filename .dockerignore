# ============================================================
# .dockerignore — Docker 构建时跳过这些文件
# ============================================================
# 作用类似 .gitignore, 但是给 Docker 看的:
#   1. 构建上下文变小, 构建快
#   2. 不把无用文件/敏感文件复制进镜像
#   3. 让缓存更有效

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
**/__pycache__/
**/*.pyc
**/*.pyo
**/.venv/
**/venv/
**/.pytest_cache/
**/.mypy_cache/

# ------------------------------------------------------------
# Node.js (容器内 npm ci 重装, 不要传 host 的)
# ------------------------------------------------------------
**/node_modules/
**/dist/
**/build/
**/.vite/
**/npm-debug.log*
**/yarn-debug.log*

# ------------------------------------------------------------
# 预生成数据 (体积大, 通过 volume 挂载提供, 不进镜像)
# ------------------------------------------------------------
backend/data/

# ------------------------------------------------------------
# Git / IDE / OS
# ------------------------------------------------------------
.git/
.gitignore
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Docker 自己 (避免循环)
# ------------------------------------------------------------
docker-compose.yml
**/Dockerfile
.dockerignore

# ------------------------------------------------------------
# Docs / README (不影响运行, 镜像不需要)
# ------------------------------------------------------------
README.md
*.md
LICENSE

# ------------------------------------------------------------
# 调试/测试脚本 (生产容器不需要)
# ------------------------------------------------------------
backend/read_test*.py
**/*.test.js
**/test-*.html