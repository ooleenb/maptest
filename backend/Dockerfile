# ============================================================
# Backend Dockerfile - Ocean Viz API
# ============================================================
# 构建一个能跑 FastAPI + xarray + dask + netCDF4 的容器
# 镜像大小约 800 MB (主要是 scipy/numpy 的 C 库)

# ------------------------------------------------------------
# 1. 基础镜像: Python 3.11 slim (精简版 Debian + Python)
# ------------------------------------------------------------
FROM python:3.11-slim

# ------------------------------------------------------------
# 2. 系统层: 装 netCDF4/HDF5 需要的 C 库
#    - libnetcdf-dev: NetCDF 文件读写
#    - libhdf5-dev:   HDF5 (NetCDF4 底层依赖)
#    - curl:          调试 / 健康检查用
#    最后清理 apt 缓存, 让镜像更小
# ------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        libnetcdf-dev \
        libhdf5-dev \
        curl \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
# 3. 工作目录: 容器内的项目根
# ------------------------------------------------------------
WORKDIR /app

# ------------------------------------------------------------
# 4. 先单独复制 requirements.txt 再 pip install
#    (重点: 这两步和下面的 COPY app/ 分开, 利用 Docker 层缓存)
#    - 改代码不改依赖: pip install 这层缓存命中, 跳过, 秒重建
#    - 改依赖时: 才重跑 pip install
# ------------------------------------------------------------
COPY requirements.txt .

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# ------------------------------------------------------------
# 5. 复制应用代码
# ------------------------------------------------------------
COPY app/ ./app/

# ------------------------------------------------------------
# 6. 创建数据目录 (会被 volume 挂载覆盖, 这里只是保证目录存在)
# ------------------------------------------------------------
RUN mkdir -p /app/data/grid /app/data/frames

# ------------------------------------------------------------
# 7. 设环境变量
#    - PYTHONUNBUFFERED=1: 让 print/log 实时输出, 不被 buffer
#    - ROMS_GRID_CACHE_DIR: 告诉 grid_meta.py 把缓存放哪
#    - ROMS_DATA_ROOT: 告诉 api.py 把预生成数据放哪
# ------------------------------------------------------------
ENV PYTHONUNBUFFERED=1 \
    ROMS_GRID_CACHE_DIR=/app/data/grid \
    ROMS_DATA_ROOT=/app/data/frames

# ------------------------------------------------------------
# 8. 暴露端口 (仅声明, 实际映射在 docker-compose.yml 控制)
# ------------------------------------------------------------
EXPOSE 8000

# ------------------------------------------------------------
# 9. 启动命令: 不用 python api.py (你那个里面有 --reload)
#    生产环境直接用 uvicorn, 单 worker 足够 (数据加载是 IO-bound)
# ------------------------------------------------------------
# CMD ["uvicorn", "app.api:app", "--host", "0.0.0.0", "--port", "8000"]
WORKDIR /app/app
CMD ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8000"]
